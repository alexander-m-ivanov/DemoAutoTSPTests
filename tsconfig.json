{
    "compilerOptions": {
        "target": "ESNext",                         // Compile to ESNext for modern JavaScript features
        "module": "NodeNext",                       // Use CommonJS module system for Node.js compatibility
        "moduleResolution": "NodeNext",                 // Resolve modules using Node.js resolution algorithm
        "strict": true,                             // Enable all strict type-checking options
        "esModuleInterop": true,                    // Enable interoperability between CommonJS and ES Modules
        "skipLibCheck": true,                       // Skip type checking of declaration files for faster compilation
        "forceConsistentCasingInFileNames": true,   // Ensure consistent casing in file names
        "outDir": "./dist",                         // Output compiled JS files to the 'dist' directory
        "rootDir": ".",                             // Set the root directory for TS source files
        "resolveJsonModule": true,                  // Allow importing JSON files as modules
        "types": ["node", "playwright"],            // Include type definitions for Node.js and Playwright
        "declaration": true,                        // Generate declaration files (.d.ts) for TypeScript modules
        "sourceMap": true                           // Generate source maps for easier debugging
    },
    "include": [
        "src/**/*.ts",                              // Include all TypeScript files in the 'src' directory and its subdirectories
        "tests/**/*.ts"                             // Include all TypeScript files in the 'tests' directory and its subdirectories
    ],
    "exclude": [
        "node_modules",                             // Exclude the 'node_modules' directory from compilation
        "dist"                                      // Exclude the 'dist' directory from compilation
    ]
}